{
  "name": "e2e(ecommerce)",
  "version": "1.0.0",
  "main": "index.js",
  "scripts": {
    "test": "playwright test",
    "test:chromium": "playwright test --project=chromium",
    "test:firefox": "playwright test --project=firefox",
    "test:webkit": "playwright test --project=webkit",
    "test:headed": "playwright test --project=chromium --headed",
    "test:headed:firefox": "playwright test --project=firefox --headed",
    "test:headed:webkit": "playwright test --project=webkit --headed",
    "test:slow": "set SLOW_MO=800 && npx playwright test --project=chromium --headed",
    "test:slow:firefox": "set SLOW_MO=800 && npx playwright test --project=firefox --headed",
    "test:slow:webkit": "set SLOW_MO=800 && npx playwright test --project=webkit --headed",
    "test:debug": "playwright test --project=chromium --debug",
    "test:debug:firefox": "playwright test --project=firefox --debug",
    "test:debug:webkit": "playwright test --project=webkit --debug",
    "report": "allure generate allure-results --clean -o allure-report && allure open allure-report"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "",
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@types/node": "^25.9.1",
    "allure-commandline": "^2.42.0",
    "allure-playwright": "^3.9.0"
  }
}
